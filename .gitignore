# =========================================================
# VibinEars Monorepo .gitignore
# Production-safe ignore rules
# =========================================================

# ---------------------------------------------------------
# Environment files - never commit real secrets
# ---------------------------------------------------------
.env
.env.*
!.env.example
!.env.development.example
!.env.staging.example
!.env.production.example

.envrc
.direnv/

# ---------------------------------------------------------
# Secrets / credentials / certificates
# ---------------------------------------------------------
*.pem
*.key
*.crt
*.cer
*.csr
*.p12
*.pfx
*.jks
*.keystore
*.mobileprovision
*.provisionprofile
*.asc
*.gpg

secrets/
.secrets/
credentials/
.credentials/
*.credentials
*.secret
*.secrets

service-account*.json
firebase-service-account*.json
google-services.json
GoogleService-Info.plist

.aws/
.gcloud/
.azure/
kubeconfig
*.kubeconfig

# ---------------------------------------------------------
# Node / JS / TS / PNPM / Turbo
# ---------------------------------------------------------
node_modules/
.pnpm-store/
.npm/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

.turbo/
.cache/
.parcel-cache/

.next/
out/
dist/
build/
coverage/
.nyc_output/
*.tsbuildinfo

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Keep package manifests and lockfiles
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!turbo.json
!tsconfig.base.json
!packages/**/package.json
!apps/**/package.json
!services/**/package.json

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

.Python
.venv/
venv/
env/
ENV/

pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
.ipynb_checkpoints/

*.egg-info/
.eggs/
wheels/

# ---------------------------------------------------------
# Backend runtime files
# ---------------------------------------------------------
logs/
*.log
uvicorn.log
gunicorn.log

celerybeat-schedule
celerybeat.pid

uploads/
media/
storage/
tmp/
temp/

# ---------------------------------------------------------
# Databases / local data
# ---------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.dump
*.sql.gz
*.backup

dump.rdb
*.rdb

postgres-data/
mongodb-data/
redis-data/
minio-data/

data/
.local-data/

# ---------------------------------------------------------
# Docker
# ---------------------------------------------------------
.docker/
docker-data/
docker-compose.override.yml

!docker-compose.yml
!docker-compose.dev.yml
!docker-compose.prod.yml

# ---------------------------------------------------------
# Terraform
# ---------------------------------------------------------
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.*
*.tfvars
*.tfvars.json
crash.log
crash.*.log

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---------------------------------------------------------
# Kubernetes / Helm secret output
# ---------------------------------------------------------
k8s-secrets/
helm-secrets/
*.sealedsecret.yaml
*.secret.yaml
*-secret.yaml
*-secrets.yaml

# ---------------------------------------------------------
# React Native / Expo / Mobile
# ---------------------------------------------------------
.expo/
.expo-shared/

android/app/build/
android/build/
android/.gradle/
android/local.properties

ios/build/
ios/Pods/
ios/Podfile.lock
ios/DerivedData/
*.xcworkspace/
*.xcuserstate
*.xcuserdata/

android/key.properties
android/*.keystore
android/app/*.keystore
ios/*.p8
ios/*.cer

# ---------------------------------------------------------
# AI / ML / Audio artifacts
# ---------------------------------------------------------
models/
checkpoints/
runs/
wandb/
mlruns/

*.pt
*.pth
*.onnx
*.engine
*.tflite
*.h5
*.pkl
*.joblib
*.ckpt

*.wav
*.mp3
*.m4a
*.flac
*.aac
recordings/
transcripts/private/
audio_samples/private/

# ---------------------------------------------------------
# Test reports / browser test output
# ---------------------------------------------------------
test-results/
playwright-report/
cypress/videos/
cypress/screenshots/

# ---------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn

# ---------------------------------------------------------
# OS generated
# ---------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------
# Backups / generated output
# ---------------------------------------------------------
*.bak
*.old
*.orig
*.tmp

scripts/output/
reports/generated/
exports/generated/

# ---------------------------------------------------------
# Keep empty folders if using .gitkeep
# ---------------------------------------------------------
!.gitkeep
